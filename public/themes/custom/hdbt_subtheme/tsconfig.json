{
  "extends": "../../contrib/hdbt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/react/common/*": ["../../contrib/hdbt/src/js/react/common/*"],
      "@/common/types/*": ["../../contrib/hdbt/src/js/types/*"],
      "@/types/*": ["../../contrib/hdbt/src/js/types/*"],
      "react": ["../../contrib/hdbt/node_modules/react"],
      "react/*": ["../../contrib/hdbt/node_modules/react/*"],
      "react-dom": ["../../contrib/hdbt/node_modules/react-dom"],
      "react-dom/*": ["../../contrib/hdbt/node_modules/react-dom/*"],
      "*": ["node_modules/*", "../../contrib/hdbt/node_modules/*"]
    },
    "downlevelIteration": true,
    "moduleResolution": "node",
    "typeRoots": [
      "./node_modules/@types",
      "./src/js/types",
      "../../contrib/hdbt/node_modules/@types",
      "../../contrib/hdbt/src/js/types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../contrib/hdbt/src/js/types"
  ]
}
